{
  "expo": {
    "name": "CampusBite",
    "slug": "campusbite",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "campusbite",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "dev.adarshg.campusbite"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "monochromeImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFDCC2"
      },
      "package": "dev.adarshg.campusbite",
      "edgeToEdgeEnabled": true,
      "usesCleartextTraffic": true
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFF8F4",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-asset",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
